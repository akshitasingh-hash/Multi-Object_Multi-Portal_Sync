<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Multi-Object Portal Sync Access</label>
    <description>Grants access to operate and monitor the Salesforce to HubSpot sync engine: the sync Apex classes, the Tombstone and Dead Letter tracking objects, the per-object governance fields, and the configuration custom metadata types.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Configuration custom metadata types (read) -->
    <customMetadataTypeAccesses>
        <name>Portal_Sync_Object__mdt</name>
        <enabled>true</enabled>
    </customMetadataTypeAccesses>
    <customMetadataTypeAccesses>
        <name>HubSpot_Field_Mapping__mdt</name>
        <enabled>true</enabled>
    </customMetadataTypeAccesses>
    <customMetadataTypeAccesses>
        <name>Portal_Sync_Association__mdt</name>
        <enabled>true</enabled>
    </customMetadataTypeAccesses>

    <!-- Apex classes (operational; test/mock classes are excluded) -->
    <classAccesses>
        <apexClass>AccountOutboxBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>AssetOutboxBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ContactOutboxBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>HubSpotService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>OpportunityOutboxBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalAssociationRouter</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalOutboxBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalRouter</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalSyncConfig</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalSyncDeadLetter</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalSyncHandler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalSyncReconciliationBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>PortalSyncScheduler</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>TombstoneOutboxBatch</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Custom tracking objects -->
    <objectPermissions>
        <object>HS_Sync_Tombstone__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>PortalSyncDeadLetter__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>true</modifyAllRecords>
    </objectPermissions>

    <!-- HS_Sync_Tombstone__c fields -->
    <fieldPermissions>
        <field>HS_Sync_Tombstone__c.Record_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>HS_Sync_Tombstone__c.Retry_Count__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>HS_Sync_Tombstone__c.SObject_Name__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>HS_Sync_Tombstone__c.Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <!-- PortalSyncDeadLetter__c fields -->
    <fieldPermissions>
        <field>PortalSyncDeadLetter__c.Error__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
