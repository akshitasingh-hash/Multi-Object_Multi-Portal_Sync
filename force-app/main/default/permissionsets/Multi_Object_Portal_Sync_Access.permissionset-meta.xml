        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>PortalSyncDeadLetter__c.Portal__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>PortalSyncDeadLetter__c.Record_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>PortalSyncDeadLetter__c.SObject_Name__c</field>
