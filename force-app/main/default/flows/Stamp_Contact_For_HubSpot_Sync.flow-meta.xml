<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>DEPRECATED / INACTIVE. Create-update stamping now lives in the ContactPortalSync before-insert/update trigger, whose watched-field set is driven entirely by the active HubSpot_Field_Mapping__mdt rows (no hardcoded field list). Deploying this as Draft deactivates the flow. Safe to delete once confirmed in production.</description>
    <environments>Default</environments>
    <interviewLabel>Stamp Contact For HubSpot Sync {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Stamp Contact For HubSpot Sync</label>
    <processType>AutoLaunchedFlow</processType>
    <status>Draft</status>

    <formulas>
        <name>PortalChanged</name>
        <dataType>Boolean</dataType>
        <expression>ISCHANGED({!$Record.Portal__c})</expression>
    </formulas>

    <assignments>
        <name>Stamp_Pending</name>
        <label>Stamp Pending</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <assignmentItems>
            <assignToReference>$Record.HS_Sync_Status__c</assignToReference>
            <operator>Assign</operator>
            <value><stringValue>Pending</stringValue></value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.HS_Portal_Changed__c</assignToReference>
            <operator>Assign</operator>
            <value><elementReference>PortalChanged</elementReference></value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.HS_Retry_Count__c</assignToReference>
            <operator>Assign</operator>
            <value><numberValue>0.0</numberValue></value>
        </assignmentItems>
    </assignments>

    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Stamp_Pending</targetReference>
        </connector>
        <object>Contact</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
</Flow>
